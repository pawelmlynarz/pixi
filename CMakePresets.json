{
  "version": 10,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
		"CMAKE_CONFIGURATION_TYPES": "DebugEditor;Debug;Release"
      }
    },
    {
      "name": "ninja-msvc",
      "inherits": "base",
      "generator": "Ninja Multi-Config",
	  "cacheVariables":
	  {
		"CMAKE_TOOLCHAIN_FILE": "${sourceDir}/engine/tools/cmake/platform/toolchains/t-x64-msvc.cmake"
	  }
    },
    {
      "name": "ninja-clang",
      "inherits": "base",
      "generator": "Ninja Multi-Config",
	  "cacheVariables":
	  {
		"CMAKE_TOOLCHAIN_FILE": "${sourceDir}/engine/tools/cmake/platform/toolchains/t-x64-clang.cmake"
	  }
    },
    {
      "name": "vs2022",
      "inherits": "base",
      "generator": "Visual Studio 17 2022",
	  "cacheVariables":
	  {
		"CMAKE_TOOLCHAIN_FILE": "${sourceDir}/engine/tools/cmake/platform/toolchains/t-x64-msvc.cmake"
	  }
    }
  ],
  "buildPresets": [
	{
      "name": "vs2022-Debug",
      "configurePreset": "vs2022",
      "configuration": "Debug"
    },
    {
      "name": "vs2022-DebugEditor",
      "configurePreset": "vs2022",
      "configuration": "DebugEditor"
    },
    {
      "name": "vs2022-Release",
      "configurePreset": "vs2022",
      "configuration": "Release"
    },
	{
      "name": "ninja-msvc-Debug",
      "configurePreset": "ninja-msvc",
      "configuration": "Debug"
    },
    {
      "name": "ninja-msvc-DebugEditor",
      "configurePreset": "ninja-msvc",
      "configuration": "DebugEditor"
    },
    {
      "name": "ninja-msvc-Release",
      "configurePreset": "ninja-msvc",
      "configuration": "Release"
    },
		{
      "name": "ninja-clang-Debug",
      "configurePreset": "ninja-clang",
      "configuration": "Debug"
    },
    {
      "name": "ninja-clang-DebugEditor",
      "configurePreset": "ninja-clang",
      "configuration": "DebugEditor"
    },
    {
      "name": "ninja-clang-Release",
      "configurePreset": "ninja-clang",
      "configuration": "Release"
    }
  ]
}
